---
import DocsLayout from "../layouts/DocsLayout.astro";
---

<DocsLayout title="Install — hemingway-ai" heading="Installation">
  <h2>Install</h2>
  <pre><code>npm install hemingway-ai</code></pre>
  <p>Or use your preferred package manager:</p>
  <pre><code>yarn add hemingway-ai
pnpm add hemingway-ai
bun add hemingway-ai</code></pre>

  <h2>Initialize</h2>
  <pre><code>npx hemingway-ai init</code></pre>
  <p>
    This creates a <code>hemingway.config.mjs</code> file in your project root
    with sensible defaults.
  </p>

  <h2>Configuration</h2>
  <p>
    All options can be set in <code>hemingway.config.mjs</code>:
  </p>
  <table>
    <thead>
      <tr>
        <th>Option</th>
        <th>Default</th>
        <th>Description</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td><code>port</code></td>
        <td><code>4800</code></td>
        <td>Server port</td>
      </tr>
      <tr>
        <td><code>model</code></td>
        <td><code>"claude-sonnet-4-6"</code></td>
        <td>Claude model to use</td>
      </tr>
      <tr>
        <td><code>styleGuide</code></td>
        <td><code>""</code></td>
        <td>Path to your brand style guide markdown</td>
      </tr>
      <tr>
        <td><code>copyBible</code></td>
        <td><code>""</code></td>
        <td>Path to your copy bible markdown</td>
      </tr>
      <tr>
        <td><code>sourcePatterns</code></td>
        <td><code>["src/**/*.tsx"]</code></td>
        <td>Glob patterns for source files to write back to</td>
      </tr>
      <tr>
        <td><code>excludePatterns</code></td>
        <td><code>["node_modules", "dist"]</code></td>
        <td>Patterns to exclude from write-back</td>
      </tr>
      <tr>
        <td><code>shortcut</code></td>
        <td><code>"meta+shift+c"</code></td>
        <td>Keyboard shortcut to toggle overlay</td>
      </tr>
      <tr>
        <td><code>accentColor</code></td>
        <td><code>"#3b82f6"</code></td>
        <td>Accent color for the overlay UI</td>
      </tr>
    </tbody>
  </table>

  <h2>Start the server</h2>
  <pre><code>npx hemingway-ai</code></pre>
  <p>
    Runs on <code>http://localhost:4800</code> by default.
  </p>

  <h2>Add to your site</h2>
  <p>Drop a script tag into your HTML:</p>
  <pre><code>&lt;script src="http://localhost:4800/client.js"&gt;&lt;/script&gt;</code></pre>

  <h2>React component</h2>
  <pre><code>import {"{"} Hemingway {"}"} from 'hemingway-ai/react';

function App() {"{"}
  return (
    &lt;&gt;
      &lt;YourApp /&gt;
      &lt;Hemingway port={"{"}4800{"}"} /&gt;
    &lt;/&gt;
  );
{"}"}</code></pre>
  <p>
    The component renders nothing visible — it injects the overlay script.
  </p>

  <h2>Environment variables</h2>
  <ul>
    <li>
      <code>ANTHROPIC_API_KEY</code> — Required. Your Anthropic API key.
    </li>
    <li>
      <code>HEMINGWAY_PORT</code> — Optional. Override the server port.
    </li>
  </ul>
</DocsLayout>
