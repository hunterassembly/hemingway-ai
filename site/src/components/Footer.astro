---
---

<footer>
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-logo">HEMINGWAY.</span>
      <span class="footer-copy">PolyForm Shield licensed. Source-available.</span>
    </div>
    <div class="footer-right">
      <a href="https://github.com/hunterassembly/hemingway-ai" class="pill-btn" target="_blank" rel="noopener noreferrer">
        GITHUB
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 2rem 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .footer-logo {
    font-size: 12px;
    font-weight: 500;
    color: var(--text);
    letter-spacing: 0;
  }

  .footer-copy {
    font-size: 12px;
    color: var(--text-muted);
  }
</style>
