---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const links = [
  { href: "/install/", label: "Install" },
  { href: "/features/", label: "Features" },
  { href: "/changelog/", label: "Changelog" },
  { href: "/faq/", label: "FAQ" },
];

function isActive(href: string, current: string): boolean {
  return current.startsWith(href);
}
---

<nav>
  <div class="nav-inner">
    <a href="/" class="logo">
      <img src="/hemingway.svg" alt="hemingway" height="20" />
    </a>
    <div class="nav-right">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={["nav-link", { active: isActive(link.href, currentPath) }]}
          aria-current={isActive(link.href, currentPath) ? "page" : undefined}
        >
          {link.label.toUpperCase()}
        </a>
      ))}
      <a
        href="https://github.com/hunterassembly/hemingway-ai"
        class="pill-btn github-btn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View on GitHub"
      >
        GITHUB
        <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background: var(--bg);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    width: 100%;
    padding: 0 24px;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
    line-height: 1;
  }

  .logo img {
    height: 20px;
    width: auto;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .nav-link {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0;
    line-height: 20px;
    transition: color 0.15s;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--text);
  }

  .github-btn {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0;
  }

  @media (max-width: 640px) {
    .nav-link {
      display: none;
    }
  }
</style>
