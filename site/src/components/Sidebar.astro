---
interface Props {
  currentPath: string;
}

const { currentPath } = Astro.props;

const navSections = [
  {
    links: [
      { href: "/", label: "Overview" },
      { href: "/install/", label: "Install" },
      { href: "/features/", label: "Features" },
      { href: "/changelog/", label: "Changelog" },
      { href: "/faq/", label: "FAQ" },
    ],
  },
];

function isActive(href: string, current: string): boolean {
  if (href === "/") return current === "/";
  return current.startsWith(href);
}
---

<aside class="sidebar">
  <div class="sidebar-inner">
    <nav class="sidebar-nav">
      {navSections.map((section) => (
        <div class="nav-section">
          {section.links.map((link) => (
            <a
              href={link.href}
              class:list={["nav-link", { active: isActive(link.href, currentPath) }]}
              aria-current={isActive(link.href, currentPath) ? "page" : undefined}
            >
              {link.label}
            </a>
          ))}
        </div>
      ))}
    </nav>

    <div class="sidebar-footer">
      <a
        href="https://www.npmjs.com/package/hemingway-ai"
        class="version-link"
        target="_blank"
        rel="noopener noreferrer"
      >v0.1.0</a>
      <span class="sidebar-dot" aria-hidden="true">&middot;</span>
      <a
        href="https://github.com/hunterassembly/hemingway-ai"
        class="github-link"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
        <svg width="9" height="9" viewBox="0 0 10 10" fill="none" aria-hidden="true">
          <path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</aside>

<style>
  .sidebar {
    position: sticky;
    top: 0;
    left: 0;
    z-index: 999;
    height: 100vh;
    display: flex;
    flex-direction: column;
  }

  .sidebar-inner {
    display: flex;
    flex-direction: column;
    min-height: 100%;
    padding: 20px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .nav-section {
    display: flex;
    flex-direction: column;
    align-items: start;
    gap: 6px;
  }

  .nav-section-title {
    font-size: 12px;
    font-weight: 500;
    color: var(--text-muted);
    margin-bottom: 4px;
    padding: 4px 0;
  }

  .nav-link {
    font-size: 18px;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
    padding: 0.5em 0.75em;
    border-radius: 9999px;
    background: var(--accent);
    transition: background 0.15s, opacity 0.2s ease, transform 0.2s ease;
    line-height: 1.4;
    backdrop-filter: blur(12px);
    user-select: none;
  }

  .nav-link:hover {
    background: var(--text);
  }

  .nav-link.active {
    background: var(--text);
  }

  @media (max-width: 640px) {
    .nav-link {
      opacity: 0;
      transform: translateY(-8px);
    }

    .nav-link:nth-child(1) { transition-delay: 0s; }
    .nav-link:nth-child(2) { transition-delay: 0.03s; }
    .nav-link:nth-child(3) { transition-delay: 0.06s; }
    .nav-link:nth-child(4) { transition-delay: 0.09s; }
    .nav-link:nth-child(5) { transition-delay: 0.12s; }
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 24px;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .sidebar-dot {
    color: var(--text-muted);
    font-size: 14px;
  }

  .github-link {
    font-size: 13px;
    color: var(--text-muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.15s;
  }

  .version-link {
    font-size: 12px;
    color: var(--text-muted);
    text-decoration: none;
    font-family: var(--font-mono);
    transition: color 0.15s;
  }

  .version-link:hover {
    color: var(--text);
  }

  .github-link:hover {
    color: var(--text);
  }
</style>
