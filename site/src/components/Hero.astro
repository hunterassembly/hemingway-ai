<section class="hero">
  <div class="hero-inner">
    <div class="hero-mark" aria-hidden="true">
      <div class="mark-box">
        <span class="mark-letter">H</span>
      </div>
    </div>

    <div class="hero-eyebrow">
      <span class="label">AI Copy Editor</span>
      <span class="dot" aria-hidden="true"></span>
      <span class="label">For developers</span>
    </div>

    <h1 class="hero-headline">
      <span class="hero-muted">Your marketing site's copy</span><br/>
      <strong>deserves a better editor.</strong>
    </h1>

    <p class="hero-subhead">
      Click any text on your dev site. Get three Claude-powered alternatives, calibrated to context and position. Apply one — it writes back to your source file.
    </p>

    <div class="hero-actions">
      <div class="install-row">
        <div class="install-command">
          <code class="install-code">npm install hemingway-ai</code>
          <button
            class="copy-btn"
            type="button"
            aria-label="Copy install command"
          >
            <svg
              width="13"
              height="13"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"
              ></path>
            </svg>
          </button>
        </div>
        <button id="demo-toggle" class="pill-btn accent demo-btn" type="button">
          Try it on this page
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <path d="M2 8L8 2M8 2H3M8 2V7" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</section>

<script>
  const copyBtn = document.querySelector(".hero .copy-btn");
  if (copyBtn) {
    copyBtn.addEventListener("click", () => {
      navigator.clipboard.writeText("npm install hemingway-ai");
      const svg = copyBtn.querySelector("svg");
      if (svg) {
        const original = svg.innerHTML;
        svg.innerHTML =
          '<polyline points="20 6 9 17 4 12" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"></polyline>';
        setTimeout(() => {
          svg.innerHTML = original;
        }, 1500);
      }
    });
  }
</script>

