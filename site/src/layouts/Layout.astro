---
import Sidebar from "../components/Sidebar.astro";

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = "AI-powered copy editing for your marketing site.",
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <input type="checkbox" id="menu-toggle" class="menu-checkbox" aria-label="Toggle menu">
    <label for="menu-toggle" class="menu-toggle">
      <svg class="menu-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M17.5401 8.81063C19.1748 8.81063 20.5001 7.48539 20.5001 5.85062C20.5001 4.21586 19.1748 2.89062 17.5401 2.89062C15.9053 2.89062 14.5801 4.21586 14.5801 5.85062C14.5801 7.48539 15.9053 8.81063 17.5401 8.81063Z" fill="currentColor"/>
        <path d="M6.46 8.81063C8.09476 8.81063 9.42 7.48539 9.42 5.85062C9.42 4.21586 8.09476 2.89062 6.46 2.89062C4.82524 2.89062 3.5 4.21586 3.5 5.85062C3.5 7.48539 4.82524 8.81063 6.46 8.81063Z" fill="currentColor"/>
        <path d="M17.5401 21.1114C19.1748 21.1114 20.5001 19.7862 20.5001 18.1514C20.5001 16.5166 19.1748 15.1914 17.5401 15.1914C15.9053 15.1914 14.5801 16.5166 14.5801 18.1514C14.5801 19.7862 15.9053 21.1114 17.5401 21.1114Z" fill="currentColor"/>
        <path d="M6.46 21.1114C8.09476 21.1114 9.42 19.7862 9.42 18.1514C9.42 16.5166 8.09476 15.1914 6.46 15.1914C4.82524 15.1914 3.5 16.5166 3.5 18.1514C3.5 19.7862 4.82524 21.1114 6.46 21.1114Z" fill="currentColor"/>
      </svg>
    </label>
    <div class="layout-container">
    <Sidebar currentPath={currentPath} />
    <div class="page-content">
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <p>
          Made by <a href="https://github.com/hunterassembly" target="_blank" rel="noopener noreferrer">Hunter Hammonds</a>
        </p>
      </footer>
    </div>
  </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";

  .layout-container {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr;
    min-height: 100vh;
    width: 100%;
  }

  .page-content {
  width: 100%;
  min-width: 0;
  min-height: 100vh;
}

.page-content main {
  width: 100%;
  padding: 40px 80px;
}

@media (max-width: 1120px) {
  .page-content main {
    padding: 40px 40px;
  }
}

/* Hamburger menu */
.menu-checkbox {
  display: none;
}

.menu-toggle {
  display: none;
  position: fixed;
  top: 16px;
  right: 16px;
  z-index: 1001;
  background: #2563EB;
  border: none;
  border-radius: 50%;
  width: 40px;
  height: 40px;
  padding: 0;
  cursor: pointer;
  color: var(--bg);
  align-items: center;
  justify-content: center;
}

.menu-toggle .menu-icon {
  transition: transform 0.25s ease;
}

.menu-checkbox:checked ~ .menu-toggle .menu-icon {
  transform: rotate(135deg);
}

@media (max-width: 640px) {
  .menu-toggle {
    display: flex;
  }

  .layout-container {
    grid-template-columns: 1fr;
  }

  .sidebar {
    position: fixed !important;
    top: 68px !important;
    right: 16px !important;
    left: auto !important;
    height: auto !important;
    z-index: 1000;
  }

  .sidebar .sidebar-inner {
    padding: 0 !important;
  }

  .sidebar .nav-section {
    align-items: flex-end !important;
  }

  .sidebar .sidebar-footer {
    display: none !important;
  }

  .menu-checkbox:checked ~ .layout-container .sidebar .nav-link {
    opacity: 1;
    transform: translateY(0);
  }

  .page-content main {
    padding: 60px 20px 40px;
  }
}
</style>
