---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  heading: string;
  description?: string;
}

const { title, heading, description } = Astro.props;
---

<Layout title={title} description={description}>
  <article class="docs-content">
    <h1>{heading}</h1>
    <slot />
  </article>
</Layout>
